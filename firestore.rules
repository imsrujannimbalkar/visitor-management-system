rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =========================================================================
    // GLOBAL HELPERS
    // =========================================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true);
    }

    function isUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Auth lookup for role-based access
    function getOrgUser(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data;
    }

    function belongsToOrg(orgId) {
      return isSignedIn() && 
        (exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)) ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId == orgId);
    }

    function isAdminOfOrg(orgId) {
      return belongsToOrg(orgId) && 
        (get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data.role == 'ADMIN' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // =========================================================================
    // VALIDATION HELPERS
    // =========================================================================

    function isValidVisit(data) {
      return data.keys().hasAll(['visitId', 'visitorPhone', 'visitorName', 'status', 'organizationId', 'recordedBy', 'recordedByName']) &&
             data.visitId is string && data.visitId.size() <= 128 &&
             data.visitorPhone is string && data.visitorPhone.size() <= 20 &&
             data.visitorName is string && data.visitorName.size() <= 128 &&
             data.status in ['INSIDE', 'CHECKED OUT', 'DELETED'] &&
             data.organizationId is string &&
             ((isSignedIn() && data.recordedBy == request.auth.uid) || (!isSignedIn() && data.recordedBy in ['KIOSK', 'EMERGENCY']));
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['organizationId', 'callerName', 'callerPhone', 'purpose', 'status', 'priority', 'recordedBy', 'recordedByName']) &&
             data.callerName is string && data.callerName.size() <= 128 &&
             data.callerPhone is string && data.callerPhone.size() <= 20 &&
             data.purpose is string && data.purpose.size() <= 1000 &&
             data.status in ['PENDING', 'DONE', 'CANCELLED'] &&
             data.priority in ['LOW', 'MEDIUM', 'HIGH'] &&
             data.recordedBy == request.auth.uid;
    }

    function isValidDonation(data) {
      return data.keys().hasAll(['id', 'organizationId', 'visitorPhone', 'amount', 'status', 'recordedBy', 'recordedByName']) &&
             data.amount is number && data.amount > 0 &&
             data.status in ['PENDING', 'CONFIRMED', 'CANCELLED', 'REFUNDED'] &&
             data.organizationId is string &&
             data.recordedBy == request.auth.uid;
    }

    function isValidPreRegistration(data) {
      return data.keys().hasAll(['name', 'phone', 'purpose', 'visitDate', 'status']) &&
             data.name is string && data.name.size() <= 100 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.status in ['PENDING', 'APPROVED', 'REJECTED', 'CHECKED_IN', 'COMPLETED'];
    }

    // =========================================================================
    // SAFETY NET
    // =========================================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // =========================================================================
    // COLLECTION RULES
    // =========================================================================

    // Top-level Invitations (Legacy/Cross-Org)
    match /invitations/{id} {
      allow read: if isSignedIn() && (resource.data.email == request.auth.token.email || resource.data.organizationId != null);
      allow create: if isVerified();
      allow update: if isSignedIn() && resource.data.email == request.auth.token.email;
    }

    // User Registry (Global Lookup)
    match /users/{uid} {
      allow get: if isUser(uid);
      allow list: if false; // No directory scraping
      allow create: if isUser(uid) && 
                      incoming().uid == uid &&
                      incoming().keys().hasAll(['uid', 'email', 'role']) &&
                      incoming().role in ['ADMIN', 'STAFF'];
      allow update: if isUser(uid) && 
                      incoming().uid == existing().uid &&
                      (incoming().organizationId == existing().organizationId || existing().organizationId == null) &&
                      (incoming().role == existing().role || existing().role == null) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'lastLogin', 'photoURL', 'preferences', 'organizationId', 'role']);
    }

    // Organization Root
    match /organizations/{orgId} {
      allow get: if belongsToOrg(orgId);
      allow create: if isVerified() && 
                      isValidId(orgId) &&
                      incoming().createdBy == request.auth.uid;
      allow update: if isAdminOfOrg(orgId) && 
                      (incoming().createdBy == existing().createdBy || !existing().keys().hasAll(['createdBy']));
      
      // ORG SUB-COLLECTIONS
      
      match /users/{userId} {
        allow read: if belongsToOrg(orgId) || isUser(userId);
        allow create: if isAdminOfOrg(orgId) || 
                       (isUser(userId) && get(/databases/$(database)/documents/organizations/$(orgId)).data.createdBy == request.auth.uid); 
        allow update: if isAdminOfOrg(orgId) || (isUser(userId) && belongsToOrg(orgId) && incoming().role == existing().role);
        allow delete: if isAdminOfOrg(orgId) && userId != request.auth.uid;
      }

      match /visitors/{phone} {
        allow read: if belongsToOrg(orgId);
        allow write: if belongsToOrg(orgId);
      }

      match /profiles/{phone} {
        allow read: if belongsToOrg(orgId);
        allow write: if (belongsToOrg(orgId) || (!isSignedIn() && incoming().organizationId == orgId));
      }

      match /visits/{visitId} {
        allow get: if belongsToOrg(orgId);
        allow list: if belongsToOrg(orgId); 
        allow create: if (belongsToOrg(orgId) || (!isSignedIn() && incoming().recordedBy == 'KIOSK')) && isValidVisit(incoming());
        allow update: if belongsToOrg(orgId) && 
                       incoming().organizationId == orgId &&
                       (isAdminOfOrg(orgId) || (incoming().recordedBy == existing().recordedBy && incoming().diff(existing()).affectedKeys().hasOnly(['checkOutTime', 'status', 'review'])));
      }

      match /donations/{donationId} {
        allow read: if belongsToOrg(orgId);
        allow create: if belongsToOrg(orgId) && isValidDonation(incoming());
        allow update: if belongsToOrg(orgId) && incoming().organizationId == orgId;
        allow delete: if isAdminOfOrg(orgId);
      }

      match /invitations/{inviteId} {
        allow read: if belongsToOrg(orgId);
        allow write: if isAdminOfOrg(orgId);
      }

      match /activityLogs/{logId} {
        allow get: if belongsToOrg(orgId);
        allow list: if isAdminOfOrg(orgId);
        allow create: if belongsToOrg(orgId) && 
                        incoming().userId == request.auth.uid &&
                        incoming().organizationId == orgId;
        allow update, delete: if false; // Audit logs are immutable
      }

      match /notifications/{notifId} {
        allow read: if belongsToOrg(orgId);
        allow write: if belongsToOrg(orgId);
      }

      match /inquiries/{inquiryId} {
        allow read: if belongsToOrg(orgId);
        allow create: if belongsToOrg(orgId) && isValidInquiry(incoming());
        allow update: if belongsToOrg(orgId) && 
                        (isAdminOfOrg(orgId) || (existing().recordedBy == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'followUpDate', 'notes', 'updatedAt', 'deleted'])));
        allow delete: if isAdminOfOrg(orgId);
      }

      match /preRegistrations/{preRegId} {
        allow read: if belongsToOrg(orgId);
        allow create: if isValidPreRegistration(incoming());
        allow update: if belongsToOrg(orgId) || (incoming().status == 'CHECKED_IN' && existing().status == 'APPROVED');
      }

      match /system_backups/{backupId} {
        allow read: if belongsToOrg(orgId);
        allow create: if isAdminOfOrg(orgId);
        allow delete: if isAdminOfOrg(orgId);
      }
    }

    // Global Public Collections
    match /appFeedback/{id} {
      allow create: if isSignedIn();
      allow read: if false; // System only
    }

    match /bugReports/{id} {
      allow create: if isSignedIn();
      allow read: if false; // System only
    }
    
    match /org_names/{name} {
      allow read: if isSignedIn();
      allow create: if isVerified();
    }
  }
}
