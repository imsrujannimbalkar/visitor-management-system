rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // BASIC HELPERS
    // =========================================================

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() &&
             request.auth.uid == uid;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function belongsToOrg(orgId) {
      return signedIn() &&
      (
        (
          userExists() &&
          userDoc().get('organizationId', '') == orgId
        )
        ||
        exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid))
        ||
        (
          exists(/databases/$(database)/documents/organizations/$(orgId)) &&
          get(/databases/$(database)/documents/organizations/$(orgId)).data.get('createdBy', '') == request.auth.uid
        )
      );
    }

    function isMasterAdmin(orgId) {
      return belongsToOrg(orgId) &&
      (
        (
          userExists() &&
          userDoc().get('role', '') == "MASTER_ADMIN"
        )
        ||
        (
          exists(/databases/$(database)/documents/organizations/$(orgId)) &&
          get(/databases/$(database)/documents/organizations/$(orgId)).data.get('createdBy', '') == request.auth.uid
        )
        ||
        (
          exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data.get('role', '') == "MASTER_ADMIN"
        )
      );
    }

    function isAdmin(orgId) {
      return belongsToOrg(orgId) &&
      (
        isMasterAdmin(orgId)
        ||
        (
          userExists() &&
          userDoc().get('role', '') == "ADMIN"
        )
        ||
        (
          exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data.get('role', '') == "ADMIN"
        )
      );
    }

    // =========================================================
    // BLOCK EVERYTHING BY DEFAULT
    // =========================================================

    match /{document=**} {
      allow read, write: if false;
    }

    // =========================================================
    // GLOBAL USERS
    // =========================================================

    match /users/{uid} {

      allow get: if
        isSelf(uid)
        ||
        (
          resource.data.organizationId != null &&
          belongsToOrg(resource.data.organizationId)
        );

      allow list: if signedIn();

      allow create: if
        isSelf(uid)
        ||
        (
          request.resource.data.organizationId != null &&
          isAdmin(request.resource.data.organizationId)
        );

      allow update: if

        // self profile updates
        (
          isSelf(uid)
          &&
          request.resource.data.role == resource.data.role
        )

        ||

        // allow role upgrade when setting up organization as owner
        (
          isSelf(uid) &&
          request.resource.data.organizationId != null &&
          exists(/databases/$(database)/documents/organizations/$(request.resource.data.organizationId)) &&
          get(/databases/$(database)/documents/organizations/$(request.resource.data.organizationId)).data.createdBy == request.auth.uid
        )

        ||

        // allow role update/set when accepting a global or org invitation
        (
          isSelf(uid) &&
          request.resource.data.organizationId != null &&
          request.resource.data.email != null &&
          (
            exists(/databases/$(database)/documents/invitations/$(request.resource.data.email.lower()))
            ||
            exists(/databases/$(database)/documents/organizations/$(request.resource.data.organizationId)/invitations/$(request.resource.data.email.lower()))
          )
        )

        ||

        // MASTER_ADMIN full control
        (
          resource.data.organizationId != null &&
          isMasterAdmin(resource.data.organizationId)
        )

        ||

        // ADMIN can manage STAFF only
        (
          resource.data.organizationId != null &&
          isAdmin(resource.data.organizationId) &&
          !isMasterAdmin(resource.data.organizationId) &&
          resource.data.role == "STAFF" &&
          request.resource.data.role in ["STAFF", "ADMIN"]
        );

      allow delete: if false;
    }

    // =========================================================
    // ORGANIZATIONS
    // =========================================================

    match /organizations/{orgId} {

      allow get: if true;

      allow create: if signedIn();

      allow update: if isAdmin(orgId);

      // =========================================================
      // ORGANIZATION USERS
      // =========================================================

      match /users/{userId} {

        allow read: if belongsToOrg(orgId) || isSelf(userId);

        allow create: if isAdmin(orgId) 
          || (isSelf(userId) && get(/databases/$(database)/documents/organizations/$(orgId)).data.createdBy == request.auth.uid)
          || (isSelf(userId) && request.resource.data.email != null && exists(/databases/$(database)/documents/invitations/$(request.resource.data.email.lower())))
          || (isSelf(userId) && request.resource.data.email != null && exists(/databases/$(database)/documents/organizations/$(orgId)/invitations/$(request.resource.data.email.lower())));

        allow update: if

          // MASTER_ADMIN full control
          (
            isMasterAdmin(orgId)
          )

          ||

          // ADMIN can manage STAFF only
          (
            isAdmin(orgId) &&
            !isMasterAdmin(orgId) &&
            resource.data.role == "STAFF" &&
            request.resource.data.role in ["STAFF", "ADMIN"]
          )

          ||

          // self updates without role change
          (
            isSelf(userId) &&
            request.resource.data.role == resource.data.role
          );

        allow delete: if

          // MASTER_ADMIN can delete anyone except creator
          (
            isMasterAdmin(orgId)
            &&
            userId != get(/databases/$(database)/documents/organizations/$(orgId)).data.createdBy
          )

          ||

          // ADMIN can delete STAFF only
          (
            isAdmin(orgId) &&
            !isMasterAdmin(orgId) &&
            resource.data.role == "STAFF"
          );
      }

      // =========================================================
      // INVITATIONS
      // =========================================================

      match /invitations/{id} {
        allow read, delete: if isAdmin(orgId) || (signedIn() && request.auth.token.email != null && request.auth.token.email.lower() == id.lower());
        allow write: if isAdmin(orgId);
      }

      // =========================================================
      // VISITORS
      // =========================================================

      match /visitors/{id} {
        allow read, write: if belongsToOrg(orgId);
      }

      // =========================================================
      // VISITS
      // =========================================================

      match /visits/{id} {
        allow read, write: if belongsToOrg(orgId);
      }

      // =========================================================
      // REVIEWS
      // =========================================================

      match /reviews/{id} {

        allow read: if belongsToOrg(orgId);

        // public review submission
        allow create: if true;

        allow update, delete: if isAdmin(orgId);
      }

      // =========================================================
      // PROFILES
      // =========================================================

      match /profiles/{id} {
        allow read, write: if belongsToOrg(orgId);
      }

      // =========================================================
      // DONATIONS
      // =========================================================

      match /donations/{id} {
        allow read, write: if belongsToOrg(orgId);
      }

      // =========================================================
      // INQUIRIES
      // =========================================================

      match /inquiries/{id} {
        allow read, write: if belongsToOrg(orgId);
      }

      // =========================================================
      // PRE REGISTRATIONS
      // =========================================================

      match /preRegistrations/{id} {
        allow read, update, delete: if belongsToOrg(orgId);
        allow create: if true;
      }

      // =========================================================
      // NOTIFICATIONS
      // =========================================================

      match /notifications/{id} {
        allow read, update, delete: if belongsToOrg(orgId);
        allow create: if true;
      }

      // =========================================================
      // ACTIVITY LOGS
      // =========================================================

      match /activityLogs/{id} {

        allow read: if belongsToOrg(orgId);

        allow create: if belongsToOrg(orgId);

        allow update, delete: if false;
      }

      // =========================================================
      // SYSTEM BACKUPS
      // =========================================================

      match /system_backups/{id} {

        allow read: if isAdmin(orgId);

        allow create: if isAdmin(orgId);

        allow delete: if isMasterAdmin(orgId);
      }
    }

    // =========================================================
    // USERS AND INVITATIONS (COLLECTION GROUP QUERIES)
    // =========================================================

    match /{path=**}/invitations/{id} {
      allow read: if signedIn() && request.auth.token.email != null && resource.data.keys().hasAll(['email']) && resource.data.email.lower() == request.auth.token.email.lower();
    }

    match /{path=**}/users/{id} {
      allow read: if signedIn() && resource.data.keys().hasAll(['uid']) && resource.data.uid == request.auth.uid;
    }

    match /invitations/{id} {
      allow read, write, delete: if signedIn();
    }

    // =========================================================
    // LEGACY TOP-LEVEL COLLECTIONS FOR MIGRATION
    // =========================================================

    match /visitors/{id} {
      allow read: if signedIn();
    }

    match /reviews/{id} {
      allow read: if signedIn();
    }

    match /activityLogs/{id} {
      allow read: if signedIn();
    }

    // =========================================================
    // FEEDBACK
    // =========================================================

    match /appFeedback/{id} {
      allow create: if signedIn();
    }

    // =========================================================
    // BUG REPORTS
    // =========================================================

    match /bugReports/{id} {
      allow create: if signedIn();
    }

    // =========================================================
    // ORG NAMES
    // =========================================================

    match /org_names/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
    }
  }
}