rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // HELPERS
    // =========================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn();
    }

    function isUser(uid) {
      return isSignedIn() &&
             request.auth.uid == uid;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function orgDoc(orgId) {
      return (
        orgId != null &&
        exists(/databases/$(database)/documents/organizations/$(orgId))
      )
      ? get(/databases/$(database)/documents/organizations/$(orgId)).data
      : { createdBy: "UNKNOWN" };
    }

    function belongsToOrg(orgId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid))
        ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid))
          &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId == orgId
        )
        ||
        (
          exists(/databases/$(database)/documents/invitations/$(request.auth.token.email)) &&
          get(/databases/$(database)/documents/invitations/$(request.auth.token.email)).data.organizationId == orgId
        )
      );
    }

    function isMasterAdmin(orgId) {
      return isSignedIn() && (
        orgDoc(orgId).createdBy == request.auth.uid ||
        (exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)) && get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data.role == 'MASTER_ADMIN') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'MASTER_ADMIN' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId == orgId)
      );
    }

    function isAdminOfOrg(orgId) {
      return isSignedIn() && (
        isMasterAdmin(orgId)
        ||
        (
          exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid))
          &&
          get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data.role
            in ['ADMIN', 'MASTER_ADMIN']
        )
        ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid))
          &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId == orgId
          &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
            in ['ADMIN', 'MASTER_ADMIN']
        )
      );
    }

    // =========================================================
    // SAFETY DEFAULT
    // =========================================================

    match /{document=**} {
      allow read, write: if false;
    }

    // =========================================================
    // GLOBAL USERS
    // =========================================================

    match /users/{uid} {

      allow get: if
        isUser(uid)
        ||
        (
          isSignedIn()
          &&
          resource.data.organizationId != null
          &&
          belongsToOrg(resource.data.organizationId)
        );

      allow list: if
        isSignedIn();

      allow create: if
        isUser(uid)
        ||
        (
          isSignedIn()
          &&
          request.resource.data.organizationId != null
          &&
          isAdminOfOrg(request.resource.data.organizationId)
        );

      allow update: if
        (
          isUser(uid) ||
          (
            isSignedIn() &&
            resource.data.organizationId != null &&
            isAdminOfOrg(resource.data.organizationId)
          )
        ) &&
        // HIERARCHY PROTECTION
        // 1. Cannot demote/modify the Organization Authority (Creator) or MASTER_ADMIN
        !(
          (resource.data.role == 'MASTER_ADMIN' || (resource.data.organizationId != null && uid == orgDoc(resource.data.organizationId).createdBy)) &&
          request.resource.data.role != resource.data.role
        ) &&
        // 2. Standard ADMINs can only modify STAFF. They cannot modify other ADMINs or promote someone to ADMIN/MASTER_ADMIN.
        !(
          (resource.data.organizationId != null && !isMasterAdmin(resource.data.organizationId)) &&
          (request.resource.data.organizationId != null && !isMasterAdmin(request.resource.data.organizationId)) && 
          (resource.data.role == "ADMIN" || request.resource.data.role == "ADMIN" || request.resource.data.role == "MASTER_ADMIN")
        );

      allow delete: if false;
    }

    // =========================================================
    // ORGANIZATIONS
    // =========================================================

    match /organizations/{orgId} {

      allow get: if belongsToOrg(orgId);

      allow create: if
        isVerified()
        &&
        incoming().createdBy == request.auth.uid;

      allow update: if isAdminOfOrg(orgId);

      // =========================================================
      // ORGANIZATION USERS
      // =========================================================

      match /users/{userId} {

        allow read: if
          belongsToOrg(orgId)
          ||
          isUser(userId);

        allow create: if
          isAdminOfOrg(orgId)
          ||
          isUser(userId);

        allow update: if
          (
            isAdminOfOrg(orgId) ||
            isUser(userId)
          ) &&
          // HIERARCHY PROTECTION
          // 1. Cannot demote/modify the Organization Authority (Creator) or MASTER_ADMIN
          !(
            (resource.data.role == 'MASTER_ADMIN' || userId == orgDoc(orgId).createdBy) &&
            request.resource.data.role != resource.data.role
          ) &&
          // 2. Standard ADMINs can only modify STAFF. They cannot modify other ADMINs or promote someone to ADMIN/MASTER_ADMIN.
          !(
            !isMasterAdmin(orgId) && 
            (request.resource.data.organizationId != null && !isMasterAdmin(request.resource.data.organizationId)) &&
            (resource.data.role == "ADMIN" || request.resource.data.role == "ADMIN" || request.resource.data.role == "MASTER_ADMIN")
          );

        allow delete: if
          isAdminOfOrg(orgId) &&
          userId != orgDoc(orgId).createdBy &&
          // Standard ADMINs cannot delete other ADMINs or MASTER_ADMINs
          (isMasterAdmin(orgId) || resource.data.role == "STAFF");
      }

      // =========================================================
      // INVITATIONS
      // =========================================================

      match /invitations/{email} {
        allow read, write, delete: if isAdminOfOrg(orgId);
      }

      // =========================================================
      // VISITORS
      // =========================================================

      match /visitors/{id} {
        allow read, write: if belongsToOrg(orgId);
      }

      // =========================================================
      // VISITS
      // =========================================================

      match /visits/{id} {
        allow read, write: if belongsToOrg(orgId);
      }

      // =========================================================
      // PROFILES
      // =========================================================

      match /profiles/{id} {
        allow read, write: if belongsToOrg(orgId);
      }

      // =========================================================
      // DONATIONS
      // =========================================================

      match /donations/{id} {
        allow read, write: if belongsToOrg(orgId);
      }

      // =========================================================
      // INQUIRIES
      // =========================================================

      match /inquiries/{id} {
        allow read, write: if belongsToOrg(orgId);
      }

      // =========================================================
      // PRE REGISTRATIONS
      // =========================================================

      match /preRegistrations/{id} {
        allow read, write: if belongsToOrg(orgId);
      }

      // =========================================================
      // NOTIFICATIONS
      // =========================================================

      match /notifications/{id} {
        allow read, write: if belongsToOrg(orgId);
      }

      // =========================================================
      // ACTIVITY LOGS
      // =========================================================

      match /activityLogs/{id} {

        allow read: if belongsToOrg(orgId);

        allow create: if belongsToOrg(orgId);

        allow update, delete: if false;
      }

      // =========================================================
      // SYSTEM BACKUPS
      // =========================================================

      match /system_backups/{id} {

        allow read: if isAdminOfOrg(orgId);

        allow create: if isAdminOfOrg(orgId);

        allow delete: if isMasterAdmin(orgId);
      }
    }

    // =========================================================
    // GLOBAL INVITATIONS
    // =========================================================

    match /invitations/{email} {

      allow read: if
        isSignedIn();

      allow create: if
        isSignedIn();

      allow update: if
        isSignedIn();

      allow delete: if
        isSignedIn();
    }

    // =========================================================
    // FEEDBACK
    // =========================================================

    match /appFeedback/{id} {
      allow create: if isSignedIn();
    }

    // =========================================================
    // BUG REPORTS
    // =========================================================

    match /bugReports/{id} {
      allow create: if isSignedIn();
    }

    // =========================================================
    // ORG NAMES
    // =========================================================

    match /org_names/{id} {

      allow read: if isSignedIn();

      allow create: if isVerified();
    }
  }
}