# Google OAuth 2.0 Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# If GOOGLE_REDIRECT_URI is not set, it will automatically use ${APP_URL}/api/google/callback
GOOGLE_REDIRECT_URI=
APP_URL=
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=/api/google/callback

# Public Firebase Config (from firebase-applet-config.json)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_DATABASE_ID=

# Gemini API Key (handled by platform)
GEMINI_API_KEY=

# Build Environment (set to 'serverless' for Vercel/Cloud Functions)
VITE_APP_BUILD_ENV=
